# ============================================
# Configuration Flask – copier vers .env
# Dev: FLASK_ENV=development | Prod: FLASK_ENV=production
# ============================================
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=True
PORT=8080

# ============================================
# Sécurité (générer en prod: python -c "import secrets; print(secrets.token_hex(32))")
# ============================================
SECRET_KEY=dev-secret-key-change-in-production
JWT_SECRET_KEY=dev-jwt-secret-change-in-production

# ============================================
# Base de données
# ============================================
# SQLite (dev)
DATABASE_URL=sqlite:///instance/portfolio_pro.db
# PostgreSQL (prod): postgresql://user:password@host:5432/portfolio_pro  # pragma: allowlist secret

# ============================================
# Redis / Cache
# ============================================
REDIS_URL=redis://localhost:6379/0

# ============================================
# CORS (domaines autorisés, séparés par des virgules)
# ============================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ============================================
# Logging (DEBUG|INFO|WARNING|ERROR)
# ============================================
LOG_LEVEL=DEBUG

# ============================================
# Rate limiting API (voir docs/RATE_LIMITING.md)
# ============================================
RATELIMIT_ENABLED=true
# Redis (avec mot de passe : redis://:MOT_DE_PASSE@host:6379/0)
# RATELIMIT_STORAGE_URL=redis://localhost:6379/1
# REDIS_URL=redis://localhost:6379
# Limites optionnelles (défauts en rate_limit_config.py) :
# RATE_LIMIT_IP_REQUESTS=100
# RATE_LIMIT_IP_WINDOW=60
# RATE_LIMIT_SEARCH_REQUESTS=60
# RATE_LIMIT_UPLOAD_REQUESTS=10
# RATE_LIMIT_DEV_MULTIPLIER=5.0
# RATE_LIMIT_PROD_MULTIPLIER=1.0
# RATE_LIMIT_ALERT_THRESHOLD=0.8
# RATE_LIMIT_LOG_WARNINGS=false
# RATE_LIMIT_LOG_ALL=false
# RATE_LIMIT_LOG_EXCEEDED=true
# RATE_LIMIT_ENABLE_METRICS=true

# ============================================
# Monitoring
# ============================================
PROMETHEUS_ENABLED=True
HEALTH_CHECK_ENABLED=True

# ============================================
# Gunicorn (production)
# ============================================
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=120

# ============================================
# GCP (optionnel, pour Cloud Run / Artifact Registry)
# ============================================
# GCP_PROJECT_ID=your-project-id
# GCP_REGION=europe-west1
